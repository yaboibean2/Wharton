# =============================================================================
# INVESTMENT ANALYSIS PLATFORM - ENVIRONMENT CONFIGURATION
# =============================================================================
#
# Copy this file to .env and fill in your API keys.
#
# DATA PROVIDER HIERARCHY (Tiered Fallback System):
# 1. Yahoo Finance (Free)     -> Primary structured data (no API key needed)
# 2. Polygon.io (Free/Premium)-> Secondary market data
# 3. Perplexity AI (Premium)  -> LLM fallback for missing fields + news/sentiment
# 4. Alpha Vantage (Free)     -> Tertiary fallback
# 5. Synthetic Data (Demo)    -> Generated only when all APIs exhausted
#
# MACRO DATA:
# 1. FRED API (Free)          -> Real economic data (yield curve, inflation, unemployment)
# 2. Hardcoded estimates      -> Fallback defaults
#
# NOTE: Yahoo Finance via yfinance requires NO API key.
#
# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# OpenAI API (REQUIRED) - Main reasoning engine for all agents (uses o3 for portfolio selection)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Perplexity API (REQUIRED) - Fallback data retrieval + sentiment news context
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# =============================================================================
# RECOMMENDED API KEYS (free)
# =============================================================================

# FRED API (RECOMMENDED) - Real macro economic data (yield curve, CPI, unemployment, fed funds)
# Get free key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Polygon.io API (RECOMMENDED) - Secondary stock data source
# Get free key from: https://polygon.io/dashboard/signup (No credit card!)
POLYGON_API_KEY=your_polygon_api_key_here

# =============================================================================
# OPTIONAL API KEYS
# =============================================================================

# Gemini API (OPTIONAL) - Second opinion for AI portfolio selection
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Alpha Vantage API (OPTIONAL) - Tertiary data fallback
# Get free key from: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# NewsAPI (OPTIONAL) - Additional news sentiment analysis
# Get free key from: https://newsapi.org/register (100 requests/day free)
NEWS_API_KEY=your_news_api_key_here

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================

# OpenAI Model Selection (for base agent analysis - portfolio selection hardcodes o3)
OPENAI_MODEL=gpt-4o-mini

# Data Cache Settings (in hours)
PRICE_DATA_CACHE_HOURS=1
FUNDAMENTAL_DATA_CACHE_HOURS=24
NEWS_CACHE_HOURS=6
REALTIME_INFO_CACHE_HOURS=0.25

# Rate Limiting (requests per minute)
POLYGON_RPM=200
PERPLEXITY_RPM=20
ALPHA_VANTAGE_RPM=5
NEWS_API_RPM=10

# Data Provider Settings
ENABLE_SYNTHETIC_DATA=true
SYNTHETIC_DATA_WARNING=false
MAX_RETRY_ATTEMPTS=3
RETRY_BACKOFF_FACTOR=2.0

# Perplexity AI Settings (used for data retrieval, not portfolio selection)
PERPLEXITY_MODEL=sonar-pro
PERPLEXITY_MAX_TOKENS=1000
ENABLE_REALTIME_INFO=true

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
